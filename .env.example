# TAKUMI — Canopy Network RPC configuration
#
# Primary node RPC endpoint. All reads and writes are attempted here first.
RPC_PRIMARY=http://127.0.0.1:50002

# Secondary (fallback) node RPC endpoint. TAKUMI automatically retries here
# if RPC_PRIMARY is unreachable or times out — see src/config/network.ts.
RPC_SECONDARY=http://127.0.0.1:50003

# Optional: chain id this client expects to talk to. Used as a sanity check
# against the node's /v1/query/height response. Leave unset to skip the check.
VITE_CHAIN_ID=1

# Optional: number of retry attempts per endpoint before failing over.
VITE_RPC_MAX_RETRIES=2

# Optional: request timeout in milliseconds before an endpoint is considered down.
VITE_RPC_TIMEOUT_MS=8000
